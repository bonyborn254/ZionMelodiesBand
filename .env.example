# Copy this file to `.env` and fill real values for development/production.
# NEVER commit real secrets to version control.

# Django
DJANGO_SECRET_KEY=changeme_replace_with_secure_random
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost:8000,http://localhost:8000

# Database: either provide DATABASE_URL or individual PG_* vars
# Example DATABASE_URL (Postgres):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# OR individual Postgres env vars:
PG_NAME=yourdbname
PG_USER=yourdbuser
PG_PASSWORD=yourdbpassword
PG_HOST=localhost
PG_PORT=5432

# Optional: enable SSL redirect in production
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
